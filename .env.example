GATEWAY_DATA_DIR=data
DEFAULT_USER_ID=user_default
DEFAULT_CONVERSATION_ID=1
CODEX_MAX_RUNTIME_SECONDS=900
# Recommended default. If a trusted local Windows device lacks
# codex-windows-sandbox-setup.exe, set only that device to danger-full-access
# in the Devices panel instead of making every device unsandboxed.
CODEX_SANDBOX_MODE=workspace-write
# Keep gateway file jobs from loading unrelated OAuth MCPs such as Linear/Slack.
CODEX_DISABLE_EXTERNAL_MCPS=true

# S3-compatible object storage. Use MinIO locally; switch these values to
# Alibaba Cloud OSS S3-compatible endpoint/credentials in production.
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:19000
OBJECT_STORAGE_BUCKET=mathpilot-dev
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin123
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ADDRESSING_STYLE=path
OBJECT_STORAGE_SIGNATURE_VERSION=s3v4
OBJECT_STORAGE_PRESIGN_EXPIRES_SECONDS=1800
OBJECT_STORAGE_AUTO_CREATE_BUCKET=true
